{
  "name": "antex",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "start": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "build": "vite build",
    "asset:audit": "node ./scripts/asset-audit.mjs",
    "check": "tsc --noEmit && node --check ./scripts/serve.mjs && node --check ./scripts/playwright-webserver.mjs && node --check ./scripts/eval-server.mjs && node --check ./scripts/verify-render.mjs && node --check ./scripts/verify-combat-outcomes.mjs && node --check ./scripts/verify-balance.mjs && node --check ./scripts/asset-audit.mjs",
    "verify": "node ./scripts/verify-render.mjs",
    "verify:combat": "node ./scripts/verify-combat-outcomes.mjs",
    "verify:balance": "node ./scripts/verify-balance.mjs",
    "test": "vitest run",
    "preeval:smoke": "node ./scripts/eval-server.mjs start",
    "eval:smoke": "playwright test tests/playwright/smoke.spec.ts tests/playwright/vision-resize.spec.ts",
    "posteval:smoke": "node ./scripts/eval-server.mjs stop",
    "preeval:save": "node ./scripts/eval-server.mjs start",
    "eval:save": "playwright test tests/playwright/save-load.spec.ts",
    "posteval:save": "node ./scripts/eval-server.mjs stop",
    "eval:ui": "playwright test --ui",
    "eval:report": "playwright show-report"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@types/three": "^0.184.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
